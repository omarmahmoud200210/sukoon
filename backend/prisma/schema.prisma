generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id             Int      @id @default(autoincrement())
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  email          String   @unique
  passwordHashed String   @map("password_hashed")
  avatarUrl      String?  @map("avatar_url") // Made optional
  isVerified     Boolean  @default(false) @map("is_verified")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  role           UserRole     @default(USER)
  oauth          Boolean  @default(false) @map("oauth")

  // Relations
  lists            List[]
  tasks            Task[]
  tags             Tag[]
  comments         Comment[]
  pomodoroTasks    PomodoroTask[]
  pomodoroSessions PomodoroSession[]
  tafreeghs        Tafreegh[]
  personalizedAyas PersonalizedAya[]

  @@index([role, createdAt])
  @@map("users")
}

model List {
  id        Int      @id @default(autoincrement())
  title     String
  color     String   @default("#000000") // Default color
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
  @@map("lists")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  userId      Int       @map("user_id")
  listId      Int?      @map("list_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  priority    Priority  @default(MEDIUM)
  isCompleted Boolean   @default(false) @map("is_completed")
  dueDate     DateTime? @map("due_date")
  deletedAt   DateTime? @map("deleted_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  list             List?             @relation(fields: [listId], references: [id], onDelete: Cascade)
  subTasks         SubTask[]
  tags             TaskTag[]
  comments         Comment[]
  pomodoroSessions PomodoroSession[]

  @@unique([id, title])
  @@index([userId, isCompleted, deletedAt])
  @@index([userId, dueDate])
  @@index([userId, deletedAt, dueDate])
  @@index([userId, isCompleted, dueDate])
  @@map("tasks")
}

model SubTask {
  id          Int     @id @default(autoincrement())
  title       String
  isCompleted Boolean @default(false) @map("is_completed")
  taskId      Int     @map("task_id")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("sub_tasks")
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks TaskTag[]

  @@index([userId])
  @@map("tags")
}

model TaskTag {
  taskId Int @map("task_id")
  tagId  Int @map("tag_id")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@map("task_tags")
}

model Comment {
  id      Int    @id @default(autoincrement())
  content String
  userId  Int    @map("user_id")
  taskId  Int    @map("task_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@map("comments")
}

model PomodoroTask {
  id         Int      @id @default(autoincrement())
  title      String
  userId     Int      @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  duration   Int
  isArchived Boolean  @default(false) @map("is_archived")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pomodoroSessions PomodoroSession[]

  @@index([userId])
  @@map("pomodoro_tasks")
}

model PomodoroSession {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  taskId         Int?     @map("task_id")
  pomodoroTaskId Int?     @map("pomodoro_task_id")
  startedAt      DateTime @map("started_at")
  endedAt        DateTime @map("ended_at")
  duration       Int
  sessionCount   Int      @default(0) @map("session_count")
  isPaused       Boolean  @default(false) @map("is_paused")
  isCompleted    Boolean  @default(false) @map("is_completed")
  timezoneOffset Int      @default(0) @map("timezone_offset")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  task         Task?         @relation(fields: [taskId], references: [id])
  pomodoroTask PomodoroTask? @relation(fields: [pomodoroTaskId], references: [id], onDelete: Cascade)

  @@index([userId, isCompleted])
  @@index([userId, isCompleted, startedAt])
  @@index([userId, taskId, isCompleted, startedAt])
  @@index([userId, pomodoroTaskId, isCompleted, startedAt])
  @@map("pomodoro_sessions")
}

model QuranAya {
  id          Int      @id @default(autoincrement())
  ayaText     String   @map("aya_text")
  ayaNumber   Int      @map("aya_number")
  surahNumber Int      @map("surah_number")
  surahName   String   @map("surah_name")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("quran_aya")
}

model PersonalizedAya {
  id          Int      @id @default(autoincrement())
  ayaText     String   @map("aya_text")
  ayaNumber   Int      @map("aya_number")
  surahNumber Int      @map("surah_number")
  surahName   String   @map("surah_name")
  reason      String   @map("reason")
  createdAt   DateTime @default(now()) @map("created_at")
  userId      Int      @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("personalized_aya")
}

model Tafreegh {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  content   String   @map("content")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("tafreegh")
}
